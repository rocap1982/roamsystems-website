---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Delivery Information" description="UK-wide delivery for ROAM Systems campervan furniture. Find out about shipping costs, lead times, and delivery options.">

  <!-- Header -->
  <section class="bg-roam-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold mb-4">Delivery Information</h1>
      <p class="text-gray-300 max-w-2xl mx-auto">Reliable delivery across the UK, from cities to remote countryside locations.</p>
    </div>
  </section>

  <!-- Delivery Info -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="text-center p-8 bg-roam-light rounded-2xl">
          <div class="w-16 h-16 mx-auto mb-4 bg-roam-orange/10 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-roam-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-2">Build Time</h3>
          <p class="text-3xl font-heading font-bold text-roam-orange mb-2">2-4 Weeks</p>
          <p class="text-gray-600 text-sm">Depending on order complexity and current demand</p>
        </div>
        <div class="text-center p-8 bg-roam-light rounded-2xl">
          <div class="w-16 h-16 mx-auto mb-4 bg-roam-orange/10 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-roam-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-2">Delivery Time</h3>
          <p class="text-3xl font-heading font-bold text-roam-orange mb-2">3-5 Days</p>
          <p class="text-gray-600 text-sm">Working days after dispatch within the UK</p>
        </div>
        <div class="text-center p-8 bg-roam-light rounded-2xl">
          <div class="w-16 h-16 mx-auto mb-4 bg-roam-orange/10 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-roam-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
          </div>
          <h3 class="font-heading text-xl font-bold mb-2">Coverage</h3>
          <p class="text-3xl font-heading font-bold text-roam-orange mb-2">UK Wide</p>
          <p class="text-gray-600 text-sm">Delivering to all areas across the United Kingdom</p>
        </div>
      </div>

      <!-- Details -->
      <div class="prose max-w-none">
        <div class="bg-white rounded-2xl shadow-md p-8 border border-gray-100 mb-8">
          <h2 class="font-heading text-2xl font-bold mb-4">How It Works</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-roam-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">1</div>
              <div>
                <h3 class="font-heading font-bold text-lg">Place Your Enquiry</h3>
                <p class="text-gray-600">Browse our products, add items to your basket, and send us your enquiry with your details.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-roam-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">2</div>
              <div>
                <h3 class="font-heading font-bold text-lg">We Contact You</h3>
                <p class="text-gray-600">Our team will get in touch to confirm your order, discuss any customisation, and arrange payment.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-roam-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">3</div>
              <div>
                <h3 class="font-heading font-bold text-lg">We Build Your Order</h3>
                <p class="text-gray-600">Your furniture is precision-crafted to order, typically taking 2-4 weeks depending on complexity.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-roam-orange rounded-full flex items-center justify-center text-white font-bold flex-shrink-0">4</div>
              <div>
                <h3 class="font-heading font-bold text-lg">Delivery & Tracking</h3>
                <p class="text-gray-600">Once dispatched, you'll receive tracking information. Delivery is typically within 3-5 working days.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-md p-8 border border-gray-100">
          <h2 class="font-heading text-2xl font-bold mb-4">Delivery Costs</h2>
          <p class="text-gray-600 mb-4">Delivery costs vary based on your order size, weight, and delivery location. We'll provide an accurate delivery quote when we contact you to confirm your order.</p>
          <p class="text-gray-600 mb-4">For a delivery estimate, please <a href="/contact" class="text-roam-orange hover:underline font-semibold">contact us</a> with your postcode and order details.</p>

          <h3 class="font-heading font-bold text-lg mt-6 mb-3">International Delivery</h3>
          <p class="text-gray-600">We currently only deliver within the United Kingdom. If you're based outside the UK, please contact us to discuss collection arrangements or alternative shipping options.</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
