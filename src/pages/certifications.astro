---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Certifications & Quality">

  <!-- Header -->
  <section class="bg-roam-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Tested & Certified</span>
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold mt-2 mb-4">Certifications & Quality</h1>
      <p class="text-gray-300 max-w-3xl mx-auto">Every ROAM Systems product is built to the highest standards. Our seating frames are independently tested and certified to M1 vehicle safety regulations, and our designs are protected by EU registered design rights.</p>
    </div>
  </section>

  <!-- M1 Safety Certification -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <div class="inline-flex items-center gap-2 bg-green-100 text-green-800 font-heading font-bold text-sm px-4 py-2 rounded-full mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            PASSED
          </div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">M1 Seat Belt Anchorage Test</h2>
          <p class="text-gray-600 text-lg mb-6">Our M1 Smart U Bed seating frame has been independently tested by the Vehicle Occupant Safety Centre (VOSC) and certified to meet the safety requirements for passenger vehicles.</p>

          <div class="bg-roam-light rounded-xl p-6 mb-6">
            <dl class="space-y-3">
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Standard</dt>
                <dd class="text-gray-600 text-right">ECE Regulation 14.09</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Directive</dt>
                <dd class="text-gray-600 text-right">76/115/EEC (2005/41/EC)</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Test Number</dt>
                <dd class="text-gray-600">VO00269</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Pull Type</dt>
                <dd class="text-gray-600">M1 Category</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Seat Belt Type</dt>
                <dd class="text-gray-600">3-Point</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Tested By</dt>
                <dd class="text-gray-600">VOSC Ltd</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Date</dt>
                <dd class="text-gray-600">18 March 2021</dd>
              </div>
            </dl>
          </div>

          <p class="text-sm text-gray-500">M1 category applies to passenger vehicles with no more than 8 seats in addition to the driver's seat. This is the highest standard for campervan seating safety.</p>
        </div>

        <div>
          <button class="cert-lightbox-btn w-full rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all cursor-pointer group border border-gray-200" data-image="/images/certs/cert-m1-seatbelt-test.jpg">
            <img src="/images/certs/cert-m1-seatbelt-test.jpg" alt="M1 Seat Belt Anchorage Test Certificate" class="w-full h-auto group-hover:scale-[1.02] transition-transform" loading="lazy" />
          </button>
          <p class="text-center text-xs text-gray-400 mt-3">Click to enlarge &bull; Watermarked copy &bull; Sensitive data redacted</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ISOFIX Certification -->
  <section class="py-20 bg-roam-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="order-2 lg:order-1">
          <button class="cert-lightbox-btn w-full rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all cursor-pointer group border border-gray-200" data-image="/images/certs/cert-isofix-test.jpg">
            <img src="/images/certs/cert-isofix-test.jpg" alt="ISOFIX Anchorage Test Certificate" class="w-full h-auto group-hover:scale-[1.02] transition-transform" loading="lazy" />
          </button>
          <p class="text-center text-xs text-gray-400 mt-3">Click to enlarge &bull; Watermarked copy &bull; Sensitive data redacted</p>
        </div>

        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 bg-green-100 text-green-800 font-heading font-bold text-sm px-4 py-2 rounded-full mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            PASSED
          </div>
          <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">ISOFIX Anchorage Test</h2>
          <p class="text-gray-600 text-lg mb-6">Our seating frame includes 2 ISOFIX child seat anchor points, independently tested and certified to ECE Regulation No. 145 for ISOFIX anchorage systems.</p>

          <div class="bg-white rounded-xl p-6 mb-6">
            <dl class="space-y-3">
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Standard</dt>
                <dd class="text-gray-600">ECE Regulation No. 145</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Test Number</dt>
                <dd class="text-gray-600">VO00270</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">ISOFIX Places</dt>
                <dd class="text-gray-600">2</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Pull Type</dt>
                <dd class="text-gray-600">Strength & Positional</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Tested By</dt>
                <dd class="text-gray-600">VOSC Ltd</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-semibold text-gray-700">Date</dt>
                <dd class="text-gray-600">23 March 2021</dd>
              </div>
            </dl>
          </div>

          <p class="text-sm text-gray-500">ISOFIX is the international standard for child safety seat attachment. Having certified ISOFIX points means families can safely use child seats in the rear of their campervan.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EU Registered Design -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-800 font-heading font-bold text-sm px-4 py-2 rounded-full mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          REGISTERED
        </div>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4">EU Registered Community Design</h2>
        <p class="text-gray-600 text-lg max-w-3xl mx-auto mb-2">Our seating and frame designs are protected by 4 EU Registered Community Designs, issued by the European Union Intellectual Property Office (EUIPO).</p>
        <p class="text-roam-orange font-heading font-semibold">RCD No. 015033319 &bull; Registered 6 September 2023</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <button class="cert-lightbox-btn rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all cursor-pointer group border border-gray-200 bg-white" data-image="/images/certs/cert-euipo-rcd-0001.jpg">
          <img src="/images/certs/cert-euipo-rcd-0001.jpg" alt="EUIPO RCD 015033319-0001" class="w-full h-auto group-hover:scale-[1.02] transition-transform" loading="lazy" />
          <div class="p-4 text-center">
            <p class="font-heading font-bold text-sm">RCD 0001</p>
            <p class="text-gray-500 text-xs">Complete Seat/Bed System</p>
          </div>
        </button>
        <button class="cert-lightbox-btn rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all cursor-pointer group border border-gray-200 bg-white" data-image="/images/certs/cert-euipo-rcd-0002.jpg">
          <img src="/images/certs/cert-euipo-rcd-0002.jpg" alt="EUIPO RCD 015033319-0002" class="w-full h-auto group-hover:scale-[1.02] transition-transform" loading="lazy" />
          <div class="p-4 text-center">
            <p class="font-heading font-bold text-sm">RCD 0002</p>
            <p class="text-gray-500 text-xs">Seat with Upholstery</p>
          </div>
        </button>
        <button class="cert-lightbox-btn rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all cursor-pointer group border border-gray-200 bg-white" data-image="/images/certs/cert-euipo-rcd-0003.jpg">
          <img src="/images/certs/cert-euipo-rcd-0003.jpg" alt="EUIPO RCD 015033319-0003" class="w-full h-auto group-hover:scale-[1.02] transition-transform" loading="lazy" />
          <div class="p-4 text-center">
            <p class="font-heading font-bold text-sm">RCD 0003</p>
            <p class="text-gray-500 text-xs">Upholstered Panels</p>
          </div>
        </button>
        <button class="cert-lightbox-btn rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all cursor-pointer group border border-gray-200 bg-white" data-image="/images/certs/cert-euipo-rcd-0004.jpg">
          <img src="/images/certs/cert-euipo-rcd-0004.jpg" alt="EUIPO RCD 015033319-0004" class="w-full h-auto group-hover:scale-[1.02] transition-transform" loading="lazy" />
          <div class="p-4 text-center">
            <p class="font-heading font-bold text-sm">RCD 0004</p>
            <p class="text-gray-500 text-xs">Steel Frame System</p>
          </div>
        </button>
      </div>

      <p class="text-center text-xs text-gray-400">Click any certificate to enlarge &bull; Watermarked copies shown &bull; Originals held on file</p>
    </div>
  </section>

  <!-- Trust Summary -->
  <section class="py-16 bg-roam-dark text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="w-16 h-16 mx-auto bg-roam-orange rounded-2xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-xl mb-2">M1 Safety Certified</h3>
          <p class="text-gray-400 text-sm">Independently tested to ECE Reg 14.09 for seat belt anchorage strength in M1 passenger vehicles.</p>
        </div>
        <div>
          <div class="w-16 h-16 mx-auto bg-roam-orange rounded-2xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4" /></svg>
          </div>
          <h3 class="font-heading font-bold text-xl mb-2">ISOFIX Certified</h3>
          <p class="text-gray-400 text-sm">2 certified ISOFIX child seat anchor points tested to ECE Regulation No. 145.</p>
        </div>
        <div>
          <div class="w-16 h-16 mx-auto bg-roam-orange rounded-2xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <h3 class="font-heading font-bold text-xl mb-2">4 EU Design Rights</h3>
          <p class="text-gray-400 text-sm">Our innovative designs are protected by 4 EU Registered Community Designs (EUIPO RCD 015033319).</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-roam-light">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold mb-4">Questions About Our Certifications?</h2>
      <p class="text-gray-600 mb-8">If you need further details about our safety certifications or registered designs, we're happy to help. Contact us directly.</p>
      <a href="/contact" class="inline-block bg-roam-orange hover:bg-roam-orange-dark text-white font-heading font-bold py-4 px-10 rounded-lg transition-all text-lg hover:scale-105">
        Contact Us
      </a>
    </div>
  </section>

  <!-- Certificate Lightbox -->
  <div id="cert-lightbox" class="fixed inset-0 z-[300] hidden bg-black/90 flex items-center justify-center">
    <button id="cert-lightbox-close" class="absolute top-4 right-4 text-white hover:text-roam-orange z-10">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <img id="cert-lightbox-image" src="" alt="Certificate preview" class="max-w-[90vw] max-h-[90vh] object-contain rounded-lg" />
  </div>

</Layout>

<script>
  // Certificate lightbox
  const certLightbox = document.getElementById('cert-lightbox');
  const certLightboxImage = document.getElementById('cert-lightbox-image') as HTMLImageElement;

  document.querySelectorAll('.cert-lightbox-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const imgSrc = (btn as HTMLElement).dataset.image;
      if (certLightboxImage && imgSrc) {
        certLightboxImage.src = imgSrc;
        certLightbox?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
    });
  });

  function closeCertLightbox() {
    certLightbox?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('cert-lightbox-close')?.addEventListener('click', closeCertLightbox);
  certLightbox?.addEventListener('click', (e) => {
    if (e.target === certLightbox) closeCertLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (certLightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeCertLightbox();
  });
</script>
