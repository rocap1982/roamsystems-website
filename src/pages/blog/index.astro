---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf());

const categoryColors: Record<string, string> = {
  guides: 'bg-blue-100 text-blue-800',
  products: 'bg-green-100 text-green-800',
  lifestyle: 'bg-purple-100 text-purple-800',
  certification: 'bg-roam-orange/10 text-roam-orange',
  news: 'bg-gray-100 text-gray-800',
};
---

<Layout title="Blog" description="Guides, tips, and insights about campervan furniture, M1 certification, and van conversions. Expert advice from ROAM Systems.">

  <!-- Page Header -->
  <section class="bg-roam-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-extrabold mb-4">Blog</h1>
      <p class="text-gray-300 max-w-2xl mx-auto">Guides, tips, and insights about campervan furniture, M1 certification, and van conversions. Expert advice from ROAM Systems.</p>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-12 bg-roam-light">
    <div class="max-w-7xl mx-auto px-4">
      {posts.length === 0 ? (
        <p class="text-center text-gray-500 py-12 text-lg">No blog posts yet. Check back soon!</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => {
            const categoryLabel = post.data.category.charAt(0).toUpperCase() + post.data.category.slice(1);
            const badgeClass = categoryColors[post.data.category] || 'bg-gray-100 text-gray-800';
            const formattedDate = post.data.publishedDate.toLocaleDateString('en-GB', {
              day: 'numeric',
              month: 'long',
              year: 'numeric',
            });
            return (
              <div class="group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100">
                <a href={`/blog/${post.id}`} class="block">
                  <div class="aspect-[4/3] overflow-hidden relative bg-gray-100">
                    {post.data.image ? (
                      <img
                        src={post.data.image}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center bg-roam-dark">
                        <span class="font-heading text-roam-orange text-4xl font-bold opacity-30">ROAM</span>
                      </div>
                    )}
                    <span class={`absolute top-4 left-4 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider ${badgeClass}`}>
                      {categoryLabel}
                    </span>
                  </div>
                  <div class="p-6">
                    <h3 class="font-heading font-bold text-lg mb-2 group-hover:text-roam-orange transition-colors">{post.data.title}</h3>
                    <p class="text-gray-600 text-sm mb-3 line-clamp-2">{post.data.description}</p>
                    <div class="flex items-center justify-between text-sm text-gray-500">
                      <time datetime={post.data.publishedDate.toISOString()}>{formattedDate}</time>
                      <span class="text-roam-orange font-semibold group-hover:underline">Read More &rarr;</span>
                    </div>
                  </div>
                </a>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>

</Layout>
