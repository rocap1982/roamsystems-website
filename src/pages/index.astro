---
import Layout from '../layouts/Layout.astro';
import products from '../data/products.json';

const findProduct = (id: string) => products.find(p => p.id === id);
const frameProduct = findProduct('m1-certified-u-shape-seating-frame');
const upholsteryProduct = findProduct('full-upholstery-kit-rear-seating-only');
const kitchenProduct = findProduct('kitchen-pod-campervan-package');
const drawerProduct = findProduct('rear-pull-out-drawer-storage-system');

const stats = [
  { number: "M1", label: "Certified Safety" },
  { number: "100+", label: "Fabric Choices" },
  { number: "220kg", label: "Runner Capacity" },
  { number: "UK", label: "Made & Delivered" },
];
---

<Layout title="Campervan Furniture Specialists">

  <!-- Hero Section - Full viewport with animated text -->
  <section class="relative bg-roam-dark text-white overflow-hidden min-h-[90vh] flex items-center">
    <div class="absolute inset-0">
      <img
        src={frameProduct?.images[0]}
        alt="ROAM Systems Campervan Furniture"
        class="w-full h-full object-cover opacity-30"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-roam-dark via-roam-dark/80 to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-24 w-full">
      <div class="max-w-2xl">
        <p class="text-roam-orange font-heading font-semibold text-lg mb-4 tracking-wider uppercase animate-fade-in">Campervan Furniture Specialists</p>
        <h1 class="font-heading text-5xl md:text-7xl font-extrabold mb-6 leading-[1.1] animate-fade-in-up">
          Your Van.<br/>
          <span class="text-roam-orange">Your Way.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-300 max-w-xl mb-10 animate-fade-in-up-delay">
          The UK's only M1 certified U-shape seating system. Premium frames, kitchens, storage and upholstery — precision-engineered for your campervan.
        </p>
        <div class="flex flex-wrap gap-4 animate-fade-in-up-delay-2">
          <a href="/products" class="bg-roam-orange hover:bg-roam-orange-dark text-white font-heading font-bold py-4 px-10 rounded-lg transition-all text-lg hover:scale-105 shadow-lg shadow-roam-orange/25">
            Shop Now
          </a>
          <a href="/gallery" class="border-2 border-white/30 hover:border-roam-orange hover:text-roam-orange text-white font-heading font-bold py-4 px-10 rounded-lg transition-all text-lg backdrop-blur-sm">
            View Gallery
          </a>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </div>
  </section>

  <!-- Stats Banner -->
  <section class="bg-roam-orange py-6">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-white text-center">
        {stats.map(stat => (
          <div>
            <p class="font-heading text-3xl md:text-4xl font-extrabold">{stat.number}</p>
            <p class="text-sm font-semibold opacity-90 uppercase tracking-wider">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Product Spotlight - M1 Frame -->
  <section class="py-20 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative">
          <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl">
            <img src={frameProduct?.images[0]} alt="M1 Certified U-Shape Seating Frame" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-6 -right-6 bg-roam-orange text-white rounded-2xl p-6 shadow-xl hidden md:block">
            <p class="font-heading text-3xl font-extrabold">From £1,850</p>
            <p class="text-sm opacity-90">+ VAT</p>
          </div>
        </div>
        <div>
          <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Featured Product</span>
          <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2 mb-6">M1 Certified U-Shape Seating Frame</h2>
          <p class="text-gray-600 text-lg mb-6">The only M1 certified U-shape seating system available. Engineered for safety with integrated 3-point seatbelts, ISOFIX points, and quick bed conversion.</p>
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-roam-light rounded-xl p-4">
              <p class="font-heading font-bold text-2xl text-roam-dark">158cm</p>
              <p class="text-gray-500 text-sm">Max Width</p>
            </div>
            <div class="bg-roam-light rounded-xl p-4">
              <p class="font-heading font-bold text-2xl text-roam-dark">170cm</p>
              <p class="text-gray-500 text-sm">Sleeping Length</p>
            </div>
            <div class="bg-roam-light rounded-xl p-4">
              <p class="font-heading font-bold text-2xl text-roam-dark">SWB/LWB</p>
              <p class="text-gray-500 text-sm">Both Available</p>
            </div>
            <div class="bg-roam-light rounded-xl p-4">
              <p class="font-heading font-bold text-2xl text-roam-dark">USB</p>
              <p class="text-gray-500 text-sm">2 Ports Built In</p>
            </div>
          </div>
          <div class="flex items-center gap-3 mb-8 text-sm text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-roam-orange flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span>EU Registered Design &bull; RCD 015033319</span>
          </div>
          <a href="/products/m1-certified-u-shape-seating-frame" class="inline-block bg-roam-dark hover:bg-roam-gray text-white font-heading font-bold py-4 px-8 rounded-lg transition-all text-lg hover:scale-105">
            View Full Details
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories - Horizontal scrolling cards on mobile -->
  <section class="py-20 bg-roam-dark text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Browse Our Range</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2">Shop By Category</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/products?category=Frames" class="relative group rounded-2xl overflow-hidden aspect-[3/4] md:aspect-[4/3]">
          <img src={frameProduct?.images[0]} alt="Frames" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent flex flex-col items-start justify-end p-8">
            <h3 class="font-heading text-3xl font-bold text-white mb-1">Frames</h3>
            <p class="text-gray-300 text-sm mb-4">M1 certified seating frames & storage</p>
            <span class="text-roam-orange font-semibold text-sm group-hover:translate-x-2 transition-transform inline-flex items-center gap-2">
              Explore Frames
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </span>
          </div>
        </a>
        <a href="/products?category=Upholstery" class="relative group rounded-2xl overflow-hidden aspect-[3/4] md:aspect-[4/3]">
          <img src={upholsteryProduct?.images[0]} alt="Upholstery" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent flex flex-col items-start justify-end p-8">
            <h3 class="font-heading text-3xl font-bold text-white mb-1">Upholstery</h3>
            <p class="text-gray-300 text-sm mb-4">Cushion boards, foam & 100+ fabric choices</p>
            <span class="text-roam-orange font-semibold text-sm group-hover:translate-x-2 transition-transform inline-flex items-center gap-2">
              Explore Upholstery
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </span>
          </div>
        </a>
        <a href="/products?category=Kitchens" class="relative group rounded-2xl overflow-hidden aspect-[3/4] md:aspect-[4/3]">
          <img src={kitchenProduct?.images[0]} alt="Kitchens" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent flex flex-col items-start justify-end p-8">
            <h3 class="font-heading text-3xl font-bold text-white mb-1">Kitchens</h3>
            <p class="text-gray-300 text-sm mb-4">Kitchen pods, lockers & solid oak worktops</p>
            <span class="text-roam-orange font-semibold text-sm group-hover:translate-x-2 transition-transform inline-flex items-center gap-2">
              Explore Kitchens
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- All Products Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Our Range</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2">All Products</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <div class="group bg-white rounded-2xl shadow-md hover:shadow-2xl transition-all duration-300 overflow-hidden border border-gray-100">
            <a href={`/products/${product.id}`} class="block">
              <div class="aspect-[4/3] overflow-hidden relative">
                <img
                  src={product.images[0]}
                  alt={product.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                {product.compareAtPrice && (
                  <span class="absolute top-4 left-4 bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full animate-pulse">SALE</span>
                )}
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors"></div>
              </div>
              <div class="p-6">
                <h3 class="font-heading font-bold text-lg mb-2 group-hover:text-roam-orange transition-colors">{product.name}</h3>
                <p class="text-gray-500 text-sm mb-3 line-clamp-2">{product.description}</p>
                <div class="flex items-center gap-3">
                  <span class="text-roam-orange font-heading font-bold text-xl">£{product.price.toFixed(2)} <span class="text-sm font-normal text-gray-500">+ VAT</span></span>
                </div>
              </div>
            </a>
            <div class="px-6 pb-6">
              <button
                class="add-to-cart-btn w-full bg-roam-dark hover:bg-roam-orange text-white font-heading font-bold py-3 px-6 rounded-lg transition-all hover:scale-[1.02]"
                data-product-id={product.id}
                data-product-name={product.name}
                data-product-price={product.price}
                data-product-image={product.images[0]}
                data-product-variant={product.variants[0].title}
              >
                Add to Basket
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-roam-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Simple Process</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          { step: "01", title: "Browse & Choose", desc: "Explore our range and add items to your basket.", icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" },
          { step: "02", title: "Send Enquiry", desc: "Submit your basket with your contact details.", icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
          { step: "03", title: "We Call You", desc: "We'll discuss your order and arrange payment.", icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" },
          { step: "04", title: "Built & Delivered", desc: "Precision-built to order and delivered to your door.", icon: "M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" },
        ].map(item => (
          <div class="text-center group">
            <div class="relative mb-6">
              <div class="w-20 h-20 mx-auto bg-white rounded-2xl shadow-lg flex items-center justify-center group-hover:shadow-xl group-hover:-translate-y-1 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-roam-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d={item.icon} /></svg>
              </div>
              <span class="absolute -top-3 -right-3 md:right-2 bg-roam-orange text-white font-heading font-extrabold text-xs w-8 h-8 rounded-full flex items-center justify-center">{item.step}</span>
            </div>
            <h3 class="font-heading font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why ROAM - Redesigned with images -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Why Us</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2">Why Choose ROAM Systems?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="group bg-roam-light rounded-2xl p-8 hover:shadow-lg transition-all flex gap-6 items-start">
          <div class="w-14 h-14 bg-roam-orange rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-xl mb-2">M1 Certified Safety</h3>
            <p class="text-gray-600">ECE 14.09 certified seating with integrated 3-point seatbelts and ISOFIX points. The only M1 certified U-shape system on the market.</p>
          </div>
        </div>
        <div class="group bg-roam-light rounded-2xl p-8 hover:shadow-lg transition-all flex gap-6 items-start">
          <div class="w-14 h-14 bg-roam-orange rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-xl mb-2">Precision Engineered</h3>
            <p class="text-gray-600">Every component is laser-cut and CNC-machined for a perfect fit. No compromises on quality or accuracy.</p>
          </div>
        </div>
        <div class="group bg-roam-light rounded-2xl p-8 hover:shadow-lg transition-all flex gap-6 items-start">
          <div class="w-14 h-14 bg-roam-orange rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-xl mb-2">Designed & Made in the UK</h3>
            <p class="text-gray-600">Manufactured by Romark Engineering Ltd in Essex. Our bed system is an EU Registered Community Design (RCD 015033319), protecting our innovative seating and frame designs.</p>
          </div>
        </div>
        <div class="group bg-roam-light rounded-2xl p-8 hover:shadow-lg transition-all flex gap-6 items-start">
          <div class="w-14 h-14 bg-roam-orange rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" /></svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-xl mb-2">Nationwide Support Network</h3>
            <p class="text-gray-600">15 approved installers across the UK. Expert help from Essex to Scotland.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src={kitchenProduct?.images[0]} alt="" class="w-full h-full object-cover opacity-20" loading="lazy" />
      <div class="absolute inset-0 bg-roam-dark/90"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center text-white">
      <h2 class="font-heading text-3xl md:text-5xl font-bold mb-6">Ready to Start Your Build?</h2>
      <p class="text-gray-300 text-lg mb-10 max-w-2xl mx-auto">Browse our products, build your basket, and send us an enquiry. We'll call you to discuss your requirements and arrange everything.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/products" class="bg-roam-orange hover:bg-roam-orange-dark text-white font-heading font-bold py-4 px-10 rounded-lg transition-all text-lg hover:scale-105 shadow-lg shadow-roam-orange/25">
          Browse Products
        </a>
        <a href="/contact" class="border-2 border-white/30 hover:border-roam-orange hover:text-roam-orange text-white font-heading font-bold py-4 px-10 rounded-lg transition-all text-lg">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 bg-roam-light">
    <div class="max-w-3xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-roam-orange font-heading font-semibold text-sm uppercase tracking-wider">Got Questions?</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mt-2">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4" id="faq-container">
        {[
          { q: "What is M1 Certification?", a: "M1 certification (ECE Regulation 14.09) is the safety standard for seats and anchorages in motor vehicles. Our U-Shape Seating Frame has been tested and certified to meet these rigorous safety requirements, including integrated 3-point seatbelts and ISOFIX points." },
          { q: "Will ROAM furniture fit my campervan?", a: "Our furniture is designed for popular campervan models. We offer both Short Wheel Base (SWB) and Long Wheel Base (LWB) configurations. If you're unsure about compatibility, please contact us with your vehicle details." },
          { q: "Can I customise my order?", a: "Yes! We offer over 100 colour and pattern choices for upholstery, and various configuration options across our product range. Contact us to discuss your specific requirements." },
          { q: "Do I need professional installation?", a: "While our products are designed for straightforward installation, we recommend professional fitting for the M1 Certified Seating Frame. Our network of approved installers can help." },
          { q: "How long does delivery take?", a: "Build time is typically 2-4 weeks depending on order complexity and current demand. After dispatch, delivery takes 3-5 working days within the UK." },
          { q: "Do you offer a warranty?", a: "Yes, all ROAM Systems products come with a warranty. Contact us for full warranty details for specific products." },
          { q: "How do I place an order?", a: "Simply browse our products, add items to your basket, and send us your enquiry. We'll contact you to discuss your requirements and arrange payment." },
          { q: "Do you deliver internationally?", a: "Currently we only deliver within the UK. For international enquiries, please contact us to discuss alternative arrangements." }
        ].map((item, i) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <button
              class="faq-toggle w-full text-left px-6 py-5 flex items-center justify-between font-heading font-semibold text-lg hover:text-roam-orange transition-colors"
              data-faq={`faq-${i}`}
            >
              <span>{item.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 transition-transform text-roam-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div id={`faq-${i}`} class="hidden px-6 pb-5 text-gray-600">
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out;
  }
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out;
  }
  .animate-fade-in-up-delay {
    animation: fadeInUp 1s ease-out 0.2s both;
  }
  .animate-fade-in-up-delay-2 {
    animation: fadeInUp 1s ease-out 0.4s both;
  }
</style>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-faq');
      const content = document.getElementById(target!);
      const icon = btn.querySelector('svg');
      if (content) {
        content.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      }
    });
  });

  // Add to cart buttons
  document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const el = btn as HTMLElement;
      (window as any).roamCart.add({
        id: el.dataset.productId,
        name: el.dataset.productName,
        price: parseFloat(el.dataset.productPrice || '0'),
        variant: el.dataset.productVariant,
        image: el.dataset.productImage
      });
      // Button feedback
      el.textContent = 'Added!';
      el.classList.add('bg-green-600');
      el.classList.remove('bg-roam-dark', 'hover:bg-roam-orange');
      setTimeout(() => {
        el.textContent = 'Add to Basket';
        el.classList.remove('bg-green-600');
        el.classList.add('bg-roam-dark', 'hover:bg-roam-orange');
      }, 1500);
    });
  });
</script>
