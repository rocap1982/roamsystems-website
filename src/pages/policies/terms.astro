        <h2 class="font-heading text-2xl font-bold mt-8">Contact Us</h2>
        <p>For questions about these terms, please contact us at <a href="mailto:sales@roamsystems.co.uk" class="text-roam-orange hover:underline">sales@roamsystems.co.uk</a>.</p>
      </div>
    </div>
  </section>
</Layout>
