---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ROAM Systems - Campervan Furniture Specialists. Premium M1 certified campervan furniture, seating frames, kitchen pods, and storage solutions.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800&family=Roboto+Condensed:wght@300;400;700&display=swap" rel="stylesheet" />
    <title>{title} | ROAM Systems</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-roam-dark text-white sticky top-0 z-50 shadow-lg">
      <div class="max-w-7xl mx-auto px-4">
        <!-- Top bar -->
        <div class="flex items-center justify-between py-3">
          <a href="/" class="flex items-center gap-3">
            <img src="/images/roam-systems-logo.png" alt="ROAM Systems" class="h-20 md:h-24 w-auto" />
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-6 font-body text-sm uppercase tracking-wider">
            <a href="/products" class="hover:text-roam-orange transition-colors">All Furniture</a>
            <a href="/products?category=Frames" class="hover:text-roam-orange transition-colors">Frames</a>
            <a href="/products?category=Upholstery" class="hover:text-roam-orange transition-colors">Upholstery</a>
            <a href="/products?category=Kitchens" class="hover:text-roam-orange transition-colors">Kitchens</a>
            <a href="/installers" class="hover:text-roam-orange transition-colors">Installers</a>
            <a href="/delivery" class="hover:text-roam-orange transition-colors">Delivery</a>
            <a href="/gallery" class="hover:text-roam-orange transition-colors">Gallery</a>
            <a href="/certifications" class="hover:text-roam-orange transition-colors">Certifications</a>
            <a href="/contact" class="hover:text-roam-orange transition-colors">Contact</a>
          </nav>

          <div class="flex items-center gap-4">
            <!-- Cart Button -->
            <button id="cart-toggle" class="relative hover:text-roam-orange transition-colors" aria-label="Open cart">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
              </svg>
              <span id="cart-count" class="absolute -top-2 -right-2 bg-roam-orange text-white text-xs rounded-full w-5 h-5 flex items-center justify-center hidden">0</span>
            </button>

            <!-- Mobile Menu Button -->
            <button id="mobile-menu-toggle" class="lg:hidden" aria-label="Toggle menu">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Nav -->
        <nav id="mobile-menu" class="lg:hidden hidden pb-4 border-t border-gray-700 pt-4">
          <div class="flex flex-col gap-3 font-body text-sm uppercase tracking-wider">
            <a href="/products" class="hover:text-roam-orange transition-colors py-1">All Furniture</a>
            <a href="/products?category=Frames" class="hover:text-roam-orange transition-colors py-1">Frames</a>
            <a href="/products?category=Upholstery" class="hover:text-roam-orange transition-colors py-1">Upholstery</a>
            <a href="/products?category=Kitchens" class="hover:text-roam-orange transition-colors py-1">Kitchens</a>
            <a href="/installers" class="hover:text-roam-orange transition-colors py-1">Installers</a>
            <a href="/delivery" class="hover:text-roam-orange transition-colors py-1">Delivery</a>
            <a href="/gallery" class="hover:text-roam-orange transition-colors py-1">Gallery</a>
            <a href="/certifications" class="hover:text-roam-orange transition-colors py-1">Certifications</a>
            <a href="/contact" class="hover:text-roam-orange transition-colors py-1">Contact</a>
          </div>
        </nav>
      </div>
    </header>

    <!-- Cart Sidebar -->
    <div id="cart-sidebar" class="fixed inset-0 z-[100] hidden">
      <div id="cart-overlay" class="absolute inset-0 bg-black/50"></div>
      <div class="absolute right-0 top-0 h-full w-full max-w-md bg-white shadow-2xl flex flex-col">
        <div class="flex items-center justify-between p-6 border-b">
          <h2 class="font-heading text-xl font-bold">Your Basket</h2>
          <div class="flex items-center gap-3">
            <button id="cart-clear" class="text-xs text-gray-400 hover:text-red-500 transition-colors hidden">Empty Basket</button>
            <button id="cart-close" class="text-gray-500 hover:text-gray-800">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
        <div id="cart-items" class="flex-1 overflow-y-auto p-6">
          <p id="cart-empty" class="text-gray-500 text-center py-8">Your basket is empty</p>
        </div>
        <div id="cart-footer" class="border-t p-6 hidden">
          <div class="flex justify-between font-heading font-bold text-lg mb-4">
            <span>Total:</span>
            <span id="cart-total">£0.00</span>
          </div>
          <div id="cart-checkout-section">
            <button id="cart-checkout-btn" class="w-full bg-roam-orange hover:bg-roam-orange-dark text-white font-heading font-bold py-3 px-6 rounded-lg transition-colors text-lg mb-2">
              Checkout &mdash; Pay Now
            </button>
            <p class="text-xs text-gray-500 text-center mb-3">Secure checkout powered by Stripe</p>
            <button id="cart-send-enquiry" class="w-full border border-gray-300 text-gray-700 hover:border-roam-orange hover:text-roam-orange font-heading font-semibold py-2 px-6 rounded-lg transition-colors text-sm">
              Or Send Enquiry Instead
            </button>
          </div>
          <div id="cart-enquiry-section" class="hidden">
            <button id="cart-send-enquiry-primary" class="w-full bg-roam-orange hover:bg-roam-orange-dark text-white font-heading font-bold py-3 px-6 rounded-lg transition-colors text-lg">
              Send Enquiry
            </button>
            <p id="cart-enquiry-hint" class="text-xs text-gray-500 text-center mt-2">Your basket contains made-to-order items &mdash; we'll contact you to arrange details and payment</p>
          </div>
          <a href="/basket" id="cart-view-full" class="block text-center text-sm text-gray-500 hover:text-roam-orange transition-colors mt-4 underline underline-offset-2">View Full Basket</a>
        </div>
      </div>
    </div>

    <!-- Enquiry Modal -->
    <div id="enquiry-modal" class="fixed inset-0 z-[200] hidden">
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
          <div class="p-6">
            <div class="flex justify-between items-center mb-4">
              <h2 class="font-heading text-2xl font-bold">Send Your Basket</h2>
              <button id="enquiry-close" class="text-gray-500 hover:text-gray-800">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
            <p class="text-gray-600 mb-6">Enter your details below and we'll get back to you to discuss your requirements, arrange payment, and organise delivery.</p>
            <form id="enquiry-form">
              <div class="space-y-4">
                <div>
                  <label for="name" class="block text-sm font-semibold mb-1">Full Name *</label>
                  <input type="text" id="name" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-roam-orange focus:border-transparent outline-none" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-semibold mb-1">Email *</label>
                  <input type="email" id="email" name="email" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-roam-orange focus:border-transparent outline-none" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold mb-1">Phone Number *</label>
                  <input type="tel" id="phone" name="phone" required class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-roam-orange focus:border-transparent outline-none" />
                </div>
                <div>
                  <label for="message" class="block text-sm font-semibold mb-1">Additional Notes</label>
                  <textarea id="message" name="message" rows="3" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:ring-2 focus:ring-roam-orange focus:border-transparent outline-none"></textarea>
                </div>
              </div>
              <button type="submit" class="w-full mt-6 bg-roam-orange hover:bg-roam-orange-dark text-white font-heading font-bold py-3 px-6 rounded-lg transition-colors text-lg">
                Send Enquiry
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-roam-dark text-white">
      <div class="max-w-7xl mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand -->
          <div>
            <div class="mb-4">
              <img src="/images/roam-systems-logo.png" alt="ROAM Systems" class="h-16 w-auto" />
            </div>
            <p class="text-gray-400 text-sm">Campervan Furniture Specialists. Premium M1 certified furniture for your dream campervan.</p>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="font-heading font-bold text-lg mb-4">Quick Links</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/products" class="hover:text-roam-orange transition-colors">All Furniture</a></li>
              <li><a href="/products?category=Frames" class="hover:text-roam-orange transition-colors">Frames</a></li>
              <li><a href="/products?category=Upholstery" class="hover:text-roam-orange transition-colors">Upholstery</a></li>
              <li><a href="/products?category=Kitchens" class="hover:text-roam-orange transition-colors">Kitchens</a></li>
              <li><a href="/gallery" class="hover:text-roam-orange transition-colors">Gallery</a></li>
            </ul>
          </div>

          <!-- Info -->
          <div>
            <h3 class="font-heading font-bold text-lg mb-4">Information</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li><a href="/installers" class="hover:text-roam-orange transition-colors">Installers</a></li>
              <li><a href="/delivery" class="hover:text-roam-orange transition-colors">Delivery</a></li>
              <li><a href="/certifications" class="hover:text-roam-orange transition-colors">Certifications</a></li>
              <li><a href="/contact" class="hover:text-roam-orange transition-colors">Contact Us</a></li>
              <li><a href="/policies/privacy" class="hover:text-roam-orange transition-colors">Privacy Policy</a></li>
              <li><a href="/policies/refund" class="hover:text-roam-orange transition-colors">Refund Policy</a></li>
              <li><a href="/policies/terms" class="hover:text-roam-orange transition-colors">Terms of Service</a></li>
              <li><a href="/policies/shipping" class="hover:text-roam-orange transition-colors">Shipping Policy</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <h3 class="font-heading font-bold text-lg mb-4">Get In Touch</h3>
            <ul class="space-y-2 text-sm text-gray-400">
              <li>
                <a href="mailto:sales@roamsystems.co.uk" class="hover:text-roam-orange transition-colors">sales@roamsystems.co.uk</a>
              </li>
              <li class="flex gap-4 pt-4">
                <a href="https://www.facebook.com/roamsystems" target="_blank" rel="noopener" class="hover:text-roam-orange transition-colors" aria-label="Facebook">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://www.youtube.com/@roamsystems" target="_blank" rel="noopener" class="hover:text-roam-orange transition-colors" aria-label="YouTube">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon fill="#fff" points="9.545,15.568 15.818,12 9.545,8.432"/></svg>
                </a>
                <a href="https://www.instagram.com/roamsystems_m1ushape" target="_blank" rel="noopener" class="hover:text-roam-orange transition-colors" aria-label="Instagram">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm text-gray-500 space-y-2">
          <p class="text-gray-400">Designed & Manufactured by <strong class="text-white">Romark Engineering Ltd</strong></p>
          <p class="flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-roam-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span>EU Registered Community Design No. 015033319</span>
          </p>
          <p>&copy; {new Date().getFullYear()} ROAM Systems. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <!-- Cart JavaScript -->
    <script>
      // Cart state management
      const cart = {
        items: JSON.parse(localStorage.getItem('roam-cart') || '[]'),

        save() {
          localStorage.setItem('roam-cart', JSON.stringify(this.items));
          this.updateUI();
        },

        add(product: {id: string, name: string, price: number, variant: string, image: string, stripePriceId?: string | null}) {
          const existing = this.items.find((item: any) => item.id === product.id && item.variant === product.variant);
          if (existing) {
            existing.qty += 1;
          } else {
            this.items.push({ ...product, qty: 1 });
          }
          this.save();
          this.openSidebar();
        },

        // Checkout is only available when every item has a real Stripe Price ID.
        // Rejects null (made-to-order), undefined (stale cart items), and
        // 'price_PLACEHOLDER' (products not yet configured in Stripe).
        canCheckout() {
          return this.items.length > 0 && this.items.every((item: any) => item.stripePriceId && item.stripePriceId !== 'price_PLACEHOLDER');
        },

        remove(index: number) {
          this.items.splice(index, 1);
          this.save();
        },

        clear() {
          if (this.items.length === 0) return;
          if (!confirm('Are you sure you want to empty your basket?')) return;
          this.items = [];
          this.save();
        },

        updateQty(index: number, qty: number) {
          if (qty <= 0) {
            this.remove(index);
          } else {
            this.items[index].qty = qty;
            this.save();
          }
        },

        getTotal() {
          return this.items.reduce((sum: number, item: any) => sum + (item.price * item.qty), 0);
        },

        getCount() {
          return this.items.reduce((sum: number, item: any) => sum + item.qty, 0);
        },

        updateUI() {
          const countEl = document.getElementById('cart-count');
          const itemsEl = document.getElementById('cart-items');
          const emptyEl = document.getElementById('cart-empty');
          const footerEl = document.getElementById('cart-footer');
          const totalEl = document.getElementById('cart-total');

          const count = this.getCount();
          if (countEl) {
            countEl.textContent = count.toString();
            countEl.classList.toggle('hidden', count === 0);
          }

          const clearBtn = document.getElementById('cart-clear');
          if (clearBtn) clearBtn.classList.toggle('hidden', this.items.length === 0);

          if (itemsEl && emptyEl && footerEl && totalEl) {
            if (this.items.length === 0) {
              emptyEl.classList.remove('hidden');
              footerEl.classList.add('hidden');
              itemsEl.innerHTML = '<p id="cart-empty" class="text-gray-500 text-center py-8">Your basket is empty</p>';
            } else {
              footerEl.classList.remove('hidden');
              totalEl.innerHTML = `£${this.getTotal().toFixed(2)} <span class="text-sm font-normal text-gray-500">+ VAT</span>`;

              // Toggle checkout vs enquiry sections
              const checkoutSection = document.getElementById('cart-checkout-section');
              const enquirySection = document.getElementById('cart-enquiry-section');
              const enquiryHint = document.getElementById('cart-enquiry-hint');
              if (checkoutSection && enquirySection) {
                const canPay = this.canCheckout();
                checkoutSection.classList.toggle('hidden', !canPay);
                enquirySection.classList.toggle('hidden', canPay);

                // Show contextual hint when checkout isn't available
                if (!canPay && enquiryHint) {
                  const hasStale = this.items.some((item: any) => !('stripePriceId' in item));
                  const hasMadeToOrder = this.items.some((item: any) => 'stripePriceId' in item && !item.stripePriceId);
                  if (hasStale && hasMadeToOrder) {
                    enquiryHint.textContent = 'Your basket contains made-to-order items and items that need to be re-added for checkout';
                  } else if (hasStale) {
                    enquiryHint.textContent = 'Some items in your basket were added before checkout was available \u2014 please re-add them to pay online';
                  } else {
                    enquiryHint.textContent = "Your basket contains made-to-order items \u2014 we'll contact you to arrange details and payment";
                  }
                }
              }

              itemsEl.innerHTML = this.items.map((item: any, i: number) => `
                <div class="flex gap-4 py-4 border-b">
                  <img src="${item.image}" alt="${item.name}" class="w-20 h-20 object-cover rounded-lg" />
                  <div class="flex-1">
                    <h3 class="font-heading font-semibold text-sm">${item.name}</h3>
                    ${item.variant !== 'Default Title' ? `<p class="text-xs text-gray-500">${item.variant}</p>` : ''}
                    <p class="text-roam-orange font-bold mt-1">£${item.price.toFixed(2)} <span class="text-xs font-normal text-gray-500">+ VAT</span></p>
                    <div class="flex items-center gap-2 mt-2">
                      <button onclick="window.roamCart.updateQty(${i}, ${item.qty - 1})" class="w-7 h-7 rounded border text-center hover:bg-gray-100 text-sm">-</button>
                      <span class="text-sm font-semibold">${item.qty}</span>
                      <button onclick="window.roamCart.updateQty(${i}, ${item.qty + 1})" class="w-7 h-7 rounded border text-center hover:bg-gray-100 text-sm">+</button>
                      <button onclick="window.roamCart.remove(${i})" class="ml-auto text-red-500 hover:text-red-700 text-xs">Remove</button>
                    </div>
                  </div>
                </div>
              `).join('');
            }
          }
        },

        openSidebar() {
          document.getElementById('cart-sidebar')?.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        },

        closeSidebar() {
          document.getElementById('cart-sidebar')?.classList.add('hidden');
          document.body.style.overflow = '';
        }
      };

      // Expose cart globally
      (window as any).roamCart = cart;

      // Init UI
      cart.updateUI();

      // Event listeners
      document.getElementById('cart-toggle')?.addEventListener('click', () => cart.openSidebar());
      document.getElementById('cart-close')?.addEventListener('click', () => cart.closeSidebar());
      document.getElementById('cart-overlay')?.addEventListener('click', () => cart.closeSidebar());
      document.getElementById('cart-clear')?.addEventListener('click', () => cart.clear());

      // Mobile menu toggle
      document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      // Checkout button — POST to /api/checkout and redirect to Stripe
      document.getElementById('cart-checkout-btn')?.addEventListener('click', async () => {
        const btn = document.getElementById('cart-checkout-btn') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Processing...';

        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              items: cart.items.map((item: any) => ({
                stripePriceId: item.stripePriceId,
                qty: item.qty,
              })),
            }),
          });

          const data = await res.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            alert(data.error || 'Something went wrong. Please try again.');
            btn.disabled = false;
            btn.innerHTML = 'Checkout &mdash; Pay Now';
          }
        } catch {
          alert('Could not connect to checkout. Please try again.');
          btn.disabled = false;
          btn.innerHTML = 'Checkout &mdash; Pay Now';
        }
      });

      // Send enquiry buttons (secondary in checkout view + primary in enquiry view)
      function openEnquiryModal() {
        cart.closeSidebar();
        const modal = document.getElementById('enquiry-modal');
        modal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';

        // Populate hidden fields
        const basketSummary = cart.items.map((item: any) =>
          `${item.name}${item.variant !== 'Default Title' ? ' (' + item.variant + ')' : ''} x${item.qty} - £${(item.price * item.qty).toFixed(2)}`
        ).join('\n');

        (window as any).__basketSummary = basketSummary;
        (window as any).__basketTotal = `£${cart.getTotal().toFixed(2)}`;
      }

      document.getElementById('cart-send-enquiry')?.addEventListener('click', openEnquiryModal);
      document.getElementById('cart-send-enquiry-primary')?.addEventListener('click', openEnquiryModal);

      // Close enquiry modal
      document.getElementById('enquiry-close')?.addEventListener('click', () => {
        document.getElementById('enquiry-modal')?.classList.add('hidden');
        document.body.style.overflow = '';
      });

      // Handle form submission
      document.getElementById('enquiry-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Sending...';

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              type: 'enquiry',
              name: (form.querySelector('#name') as HTMLInputElement).value,
              email: (form.querySelector('#email') as HTMLInputElement).value,
              phone: (form.querySelector('#phone') as HTMLInputElement).value,
              message: (form.querySelector('#message') as HTMLTextAreaElement).value,
              basketItems: (window as any).__basketSummary || '',
              basketTotal: (window as any).__basketTotal || '',
            }),
          });

          if (!res.ok) throw new Error('Failed to send');

          cart.items = [];
          cart.save();
          document.getElementById('enquiry-modal')?.classList.add('hidden');
          document.body.style.overflow = '';
          alert('Thank you! Your enquiry has been sent. We will contact you shortly to arrange payment and delivery.');
        } catch {
          alert('Sorry, there was an error sending your enquiry. Please try again or contact us directly at sales@roamsystems.co.uk');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send Enquiry';
        }
      });
    </script>
  </body>
</html>
